    %% Styles
    classDef primitive fill:#1a3a5c,stroke:#4a7aac,color:#e0e0e0
    classDef renderer fill:#1a4a3a,stroke:#4aaa7a,color:#e0e0e0
    classDef composite fill:#3a2a5c,stroke:#7a5aac,color:#e0e0e0
    classDef workflow fill:#5c2a2a,stroke:#ac5a5a,color:#e0e0e0
    classDef external fill:#2a2a2a,stroke:#6a6a6a,color:#aaaaaa,stroke-dasharray: 5 5
    classDef highlight fill:#2a4a1a,stroke:#6aaa3a,color:#e0e0e0,stroke-width:3px

    class PL,TP,CB,BG primitive
    class TV,TL,D2,NB renderer
    class MMM,MM highlight
    class DB,CM,RP composite
    class WF1,WF2 workflow
    class NT,GH,SK,N8N external
